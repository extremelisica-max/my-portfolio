6 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  user personas,}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1057 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2021 \emdash  \uc0\u1071 \uc0\u1085 \uc0\u1074 \uc0\u1072 \uc0\u1088 \uc0\u1100  2023\line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  5 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b Control Sistems}\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1074 \uc0\u1072 , controlsystems.ru/}\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1077 \uc0\u1088 \par}\pard\intbl\itap1\sl260\sa60{\fs18 CRM-\uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1072  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1082 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1085 \uc0\u1077 \uc0\u1092 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1087 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1081 : \uc0\u1043 \uc0\u1072 \uc0\u1079 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1084 , \uc0\u1051 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1081 \uc0\u1083 , \uc0\u1043 \uc0\u1072 \uc0\u1079 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1084 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 .{\line}\uc0\u8212  \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1072 \uc0\u1088 \uc0\u1080 \uc0\u1077 \uc0\u1074  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1074 \uc0\u1077 \uc0\u1073 -\uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1092 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1086 \uc0\u1074  B2B-\uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1099 {\line}\uc0\u8212  \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1089 \uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1072 \uc0\u1088 \uc0\u1080 \uc0\u1077 \uc0\u1074  \uc0\u1080  \uc0\u1096 \uc0\u1072 \uc0\u1075 \uc0\u1086 \uc0\u1074  \uc0\u1074 \uc0\u1079 \uc0\u1072 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1080 \uc0\u1103  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103  \uc0\u1089  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1084 {\line}\uc0\u8212  \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1076 \uc0\u1072 \uc0\u1096 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1076 \uc0\u1086 \uc0\u1074 : \uc0\u1083 \uc0\u1080 \uc0\u1085 \uc0\u1077 \uc0\u1081 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1080 , \uc0\u1073 \uc0\u1072 \uc0\u1088 \uc0\u1099 , \uc0\u1074 \uc0\u1080 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1090 \uc0\u1099 , \uc0\u1090 \uc0\u1072 \uc0\u1073 \uc0\u1083 \uc0\u1080 \uc0\u1094 \uc0\u1099 , \uc0\u1090 \uc0\u1077 \uc0\u1087 \uc0\u1083 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1077  \uc0\u1082 \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1099 {\line}\uc0\u8212  \uc0\u1054 \uc0\u1090 \uc0\u1088 \uc0\u1080 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1086 \uc0\u1082  \uc0\u1080  \uc0\u1080 \uc0\u1083 \uc0\u1083 \uc0\u1102 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1081 {\line}\uc0\u8212  \uc0\u1050 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  \uc0\u1088 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1092 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1072 , \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 -\uc0\u1088 \uc0\u1077 \uc0\u1074 \uc0\u1100 \uc0\u1102 {\line}\uc0\u8212  \uc0\u1057 \uc0\u1086 \uc0\u1079 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1090 \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1074 {\line}\uc0\u8212  \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1082 \uc0\u1072  \uc0\u1075 \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1079  \uc0\u1095 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1079  \uc0\u1102 \uc0\u1079 \uc0\u1072 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 -\uc0\u1090 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1054 \uc0\u1082 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2020 \emdash  \uc0\u1060 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100  2022\line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  5 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b -}\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1074 \uc0\u1072 , -}\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 UX/UI \uc0\u1044 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1077 \uc0\u1088 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u8212  \uc0\u1051 \uc0\u1077 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1085 \uc0\u1075 \uc0\u1080 , \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1084 \uc0\u1086 -\uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1094 \uc0\u1099 , \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1079 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 {\line}\uc0\u8212  \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1090 \uc0\u1080 \uc0\u1087 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1084 \uc0\u1086 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1080  \uc0\u1076 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1087 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1081  \uc0\u1089 \uc0\u1072 \uc0\u1081 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1073 \uc0\u1086 \uc0\u1088  \uc0\u1088 \uc0\u1077 \uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1086  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1086 \uc0\u1079 \uc0\u1080 \uc0\u1094 \uc0\u1080 \uc0\u1080 {\line}\uc0\u8212  \uc0\u1052 \uc0\u1091 \uc0\u1076 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1076 \uc0\u1099 : \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1094 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1074 \uc0\u1086 \uc0\u1081  \uc0\u1072 \uc0\u1091 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1080 , \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1073 \uc0\u1086 \uc0\u1088  \uc0\u1088 \uc0\u1077 \uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1086  \uc0\u1096 \uc0\u1088 \uc0\u1080 \uc0\u1092 \uc0\u1090 \uc0\u1072 \uc0\u1084 , \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1084  \uc0\u1080  \uc0\u1094 \uc0\u1074 \uc0\u1077 \uc0\u1090 \uc0\u1091 {\line}\uc0\u8212  \uc0\u1050 \uc0\u1086 \uc0\u1085 \uc0\u1082 \uc0\u1091 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 , \uc0\u1074 \uc0\u1099 \uc0\u1103 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1073 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1081 , \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1097 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1092 \uc0\u1091 \uc0\u1085 \uc0\u1082 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1072 , \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  UI-\uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1094 \uc0\u1077 \uc0\u1087 \uc0\u1094 \uc0\u1080 \uc0\u1081 {\line}\uc0\u8212  \uc0\u1042 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1090 \uc0\u1082 \uc0\u1080 , \uc0\u1073 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1099 , \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1080 \uc0\u1087 \uc0\u1099 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sl220{\fs22\uc0\u1057 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1077 \uc0\u1077  \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2016\line \uc0\u1057 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1077 \uc0\u1077  \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077 }\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1055 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1075 \uc0\u1086 \uc0\u1089 \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1088 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090  \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1084 \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1081  \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1082 \uc0\u1080 , \uc0\u1057 \uc0\u1072 \uc0\u1084 \uc0\u1072 \uc0\u1088 \uc0\u1072 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1047 \uc0\u1072 \uc0\u1086 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1077 , \uc0\u1048 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1080  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 2010\line \uc0\u1057 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1077 \uc0\u1077  \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077 }\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1055 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1082 \uc0\u1086 \uc0\u1083 \uc0\u1083 \uc0\u1077 \uc0\u1076 \uc0\u1078 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1054 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1077 , IT}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1055 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1074 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1082 \uc0\u1091 \uc0\u1088 \uc0\u1089 \uc0\u1099 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2020}\cell\pard\intbl\itap1\sl280{\fs24\b WDI design}\par\pard\intbl\itap1\sl260{\fs18 WDI, \uc0\u1044 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1077 \uc0\u1088  UX\\UI}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1047 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1086 \uc0\u1074 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1056 \uc0\u1091 \uc0\u1089 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  \uc0\u1056 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086 \uc0\u1081 }\par \uc0\u1040 \uc0\u1085 \uc0\u1075 \uc0\u1083 \uc0\u1080 \uc0\u1081 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  A1 \uc0\u8212  \uc0\u1053 \uc0\u1072 \uc0\u1095 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081 }}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\pard\intbl\itap1\sb250\sl260{\fs18 {\cb5\chcfpat5\chcbpat5 Figma}  {\cb5\chcfpat5\chcbpat5 Adobe\~Photoshop}  {\cb5\chcfpat5\chcbpat5 UX/UI}  {\cb5\chcfpat5\chcbpat5 Prototyping}  {\cb5\chcfpat5\chcbpat5 Tilda}  {\cb5\chcfpat5\chcbpat5 Web\~Design}  {\cb5\chcfpat5\chcbpat5 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 \~\uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1079 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072