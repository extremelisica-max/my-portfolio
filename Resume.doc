}\cell\pard\intbl\itap1{\fs50\b \uc0\u1050 \uc0\u1072 \uc0\u1088 \uc0\u1089 \uc0\u1091 \uc0\u1085 \uc0\u1094 \uc0\u1077 \uc0\u1074  \uc0\u1040 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1088  \uc0\u1040 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1089 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1095 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1052 \uc0\u1091 \uc0\u1078 \uc0\u1095 \uc0\u1080 \uc0\u1085 \uc0\u1072 , 36\uc0\u160 \uc0\u1083 \uc0\u1077 \uc0\u1090 , \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1083 \uc0\u1089 \uc0\u1103  9 \uc0\u1080 \uc0\u1102 \uc0\u1085 \uc0\u1103  1989}\par\pard\intbl\sl260{\fs18 \par +7\uc0\u160 (939)\uc0\u160 7066663 {\cf1\emdash  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1086 \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1073  \uc0\u1089 \uc0\u1074 \uc0\u1103 \uc0\u1079 \uc0\u1080 } {\cf1  \uc0\u8226  } {\cf1*\uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1092 \uc0\u1086 \uc0\u1085  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1074 \uc0\u1103 \uc0\u1079 \uc0\u1072 \uc0\u1085  \uc0\u1082  WhatsApp}\par {{\field{\*\fldinst HYPERLINK "mailto:extremelisica@gmail.com"}{\fldrslt\ul extremelisica@gmail.com}}}}\par\pard\intbl\sl260{\fs18 \par \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1077 \uc0\u1090 : \uc0\u1057 \uc0\u1072 \uc0\u1084 \uc0\u1072 \uc0\u1088 \uc0\u1072 \par \uc0\u1043 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 , \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1085 \uc0\u1072  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1091 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 \par \uc0\u1043 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1090 \uc0\u1100  \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1083 \uc0\u1105 \uc0\u1085 \uc0\u1085 \uc0\u1086 , \uc0\u1085 \uc0\u1077  \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 \uc0\u1084 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1088 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1072 }\cell\row\trowd\cellx6861\clvertalt\cellx9638\pard\intbl\itap1\sa100\sl280{\fs24\b Product Designer | B2B SaaS, CRM}\pard\intbl\itap1\sl260{\fs18 \par{\uc0\u1057 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 :  }\par\li300{\uc0\u8212   \uc0\u1044 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1077 \uc0\u1088 , \uc0\u1093 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1078 \uc0\u1085 \uc0\u1080 \uc0\u1082 }\par\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1058 \uc0\u1080 \uc0\u1087  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 : \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 \par \uc0\u1060 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1083 \uc0\u1105 \uc0\u1085 \uc0\u1085 \uc0\u1086 \par \line\uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1074  \uc0\u1087 \uc0\u1091 \uc0\u1090 \uc0\u1080  \uc0\u1076 \uc0\u1086  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1077  \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1077 \uc0\u1090  \uc0\u1079 \uc0\u1085 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }}\cell \pard\intbl\itap1\qr{\fs32\qc\b 180\uc0\u160 000\fs18\sl260  \uc0\u8381  \uc0\u1085 \uc0\u1072 \uc0\u160 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1080 }\par\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \emdash 5 \uc0\u1083 \uc0\u1077 \uc0\u1090  3 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1072 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1060 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100  2025 \emdash  \uc0\u1044 \uc0\u1077 \uc0\u1082 \uc0\u1072 \uc0\u1073 \uc0\u1088 \uc0\u1100  2025\line 11 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\par\cell\pard\intbl\itap1\sl280{\fs24\b Gmini}\par\pard\intbl\itap1\sl260{\fs18\cf1 }\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1077 \uc0\u1088 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1091 \uc0\u1102  \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1092 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1099  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1057 \uc0\u1054 \uc0\u1044  \uc0\u8212  SaaS-\uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1099  \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1084 \uc0\u1080  \uc0\u1085 \uc0\u1072  \uc0\u1074 \uc0\u1089 \uc0\u1077 \uc0\u1093  \uc0\u1101 \uc0\u1090 \uc0\u1072 \uc0\u1087 \uc0\u1072 \uc0\u1093  \uc0\u1078 \uc0\u1080 \uc0\u1079 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1094 \uc0\u1080 \uc0\u1082 \uc0\u1083 \uc0\u1072  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 .{\line}{\line}\uc0\u1050 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1074 \uc0\u1099 \uc0\u1077  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 :{\line}- \uc0\u1057 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1099  \uc0\u1079 \uc0\u1072 \uc0\u1084 \uc0\u1077 \uc0\u1095 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1081  \uc0\u1080  \uc0\u1089 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1081  \uc0\u8212  \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1083  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1089 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1085 \uc0\u1072  40% (\uc0\u1087 \uc0\u1086  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1084  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1099 ){\line}- \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1082 \uc0\u1072 \uc0\u1090 \uc0\u1072 \uc0\u1083 \uc0\u1086 \uc0\u1075  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 : \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1072 , \uc0\u1085 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1075 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 , \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1072  \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1072  \uc0\u1080  \uc0\u1092 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 {\line}- \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1105 \uc0\u1083  15+ \uc0\u1075 \uc0\u1083 \uc0\u1091 \uc0\u1073 \uc0\u1080 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1100 \uc0\u1102  \uc0\u1089  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1088 \uc0\u1103 \uc0\u1076 \uc0\u1095 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1095 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1084 \uc0\u1080 , \uc0\u1089 \uc0\u1086 \uc0\u1079 \uc0\u1076 \uc0\u1072 \uc0\u1083  CJM \uc0\u1080  3 user personas{\line}- \uc0\u1057 \uc0\u1086 \uc0\u1079 \uc0\u1076 \uc0\u1072 \uc0\u1083  \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 -\uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1091  \uc0\u1089  \uc0\u1085 \uc0\u1091 \uc0\u1083 \uc0\u1103 : \uc0\u1094 \uc0\u1074 \uc0\u1077 \uc0\u1090 \uc0\u1072 , \uc0\u1090 \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 , \uc0\u1073 \uc0\u1080 \uc0\u1073 \uc0\u1083 \uc0\u1080 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1072  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1086 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1075 \uc0\u1072 \uc0\u1081 \uc0\u1076 \uc0\u1083 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1099 {\line}- \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1083  AB-\uc0\u1090 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1099  \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1092 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1081 , \uc0\u1079 \uc0\u1072 \uc0\u1097 \uc0\u1080 \uc0\u1097 \uc0\u1072 \uc0\u1083  \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1076  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1072 \uc0\u1084 \uc0\u1080  Discovery \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080 {\line}{\line}\uc0\u1048 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 : Figma, FigJam, Miro, \uc0\u1082 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1076 \uc0\u1086 \uc0\u1088 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1090 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1060 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100  2023 \emdash  \uc0\u1071 \uc0\u1085 \uc0\u1074 \uc0\u1072 \uc0\u1088 \uc0\u1100  2025\line 2 \uc0\u1075 \uc0\u1086 \uc0\u1076 \uc0\u1072 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b OnePix}\par\pard\intbl\itap1\sl260{\fs18\cf1 onepix.ru/}\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1077 \uc0\u1088 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1085 \uc0\u1072 \uc0\u1076  \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1086 \uc0\u1084  4 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1074  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1085 \uc0\u1080 \uc0\u1096 \uc0\u1072 \uc0\u1093 : \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1080 \uc0\u1079 \uc0\u1084 , \uc0\u1082 \uc0\u1088 \uc0\u1080 \uc0\u1087 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1080 \uc0\u1085 \uc0\u1075 , \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1084 \uc0\u1077 \uc0\u1088 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1074 \uc0\u1080 \uc0\u1078 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 .{\line}{\line}\uc0\u1050 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1074 \uc0\u1099 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1099 :{\line}{\line}\uc0\u8250  Effaliya \uc0\u8212  \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1073 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1081  (B2B/B2C){\line}- \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1105 \uc0\u1083  \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085  MVP: \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1083  \uc0\u1087 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082  \uc0\u1080  \uc0\u1092 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102 , \uc0\u1076 \uc0\u1086 \uc0\u1073 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1083  \uc0\u1088 \uc0\u1077 \uc0\u1081 \uc0\u1090 \uc0\u1080 \uc0\u1085 \uc0\u1075 \uc0\u1080 , \uc0\u1086 \uc0\u1090 \uc0\u1079 \uc0\u1099 \uc0\u1074 \uc0\u1099  \uc0\u1080  \uc0\u1095 \uc0\u1072 \uc0\u1090  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1078 \uc0\u1082 \uc0\u1080 {\line}- \uc0\u1044 \uc0\u1083 \uc0\u1103  \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1077 \uc0\u1088 \uc0\u1086 \uc0\u1074 : \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1083  \uc0\u1096 \uc0\u1072 \uc0\u1093 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1082 \uc0\u1091  \uc0\u1073 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1081 , \uc0\u1091 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1096 \uc0\u1080 \uc0\u1083  Drag&Drop, \uc0\u1089 \uc0\u1086 \uc0\u1079 \uc0\u1076 \uc0\u1072 \uc0\u1083  \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1102  \uc0\u1076 \uc0\u1086 \uc0\u1073 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103  \uc0\u1080  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1091  \uc0\u1089 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 {\line}- \uc0\u1044 \uc0\u1083 \uc0\u1103  \uc0\u1072 \uc0\u1076 \uc0\u1084 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074 : \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1083  \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1102  \uc0\u1080 \uc0\u1079 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081 {\line}- \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1105 \uc0\u1083  \uc0\u1088 \uc0\u1077 \uc0\u1073 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1085 \uc0\u1075 : \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1080 \uc0\u1087  \uc0\u1080  \uc0\u1074 \uc0\u1080 \uc0\u1079 \uc0\u1091 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1083 \uc0\u1100 {\line}{\line}\uc0\u8250  Vnish \uc0\u8212  \uc0\u1072 \uc0\u1075 \uc0\u1088 \uc0\u1077 \uc0\u1075 \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1088  \uc0\u1086 \uc0\u1073 \uc0\u1086 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1084 \uc0\u1072 \uc0\u1081 \uc0\u1085 \uc0\u1080 \uc0\u1085 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1092 \uc0\u1077 \uc0\u1088 \uc0\u1084 {\line}- \uc0\u1056 \uc0\u1077 \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1086 \uc0\u1074 : Pulse, \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1086 \uc0\u1095 \uc0\u1085 \uc0\u1080 \uc0\u1082 , \uc0\u1082 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1082 \uc0\u1091 \uc0\u1083 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1099  \uc0\u1093 \uc0\u1077 \uc0\u1096 \uc0\u1088 \uc0\u1077 \uc0\u1081 \uc0\u1090 \uc0\u1072 , \uc0\u1074 \uc0\u1072 \uc0\u1082 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1080 \uc0\u1080  \uc0\u1080  \uc0\u1088 \uc0\u1077 \uc0\u1079 \uc0\u1102 \uc0\u1084 \uc0\u1077 {\line}- \uc0\u1059 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1083  \uc0\u1085 \uc0\u1072 \uc0\u1074 \uc0\u1080 \uc0\u1075 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1102  \uc0\u1080  \uc0\u1091 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1096 \uc0\u1080 \uc0\u1083  \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1089 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093 {\line}{\line}\uc0\u8250  ABA \uc0\u8212  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1087 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1074 {\line}- \uc0\u1056 \uc0\u1077 \uc0\u1076 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1081 \uc0\u1085  \uc0\u1089 \uc0\u1072 \uc0\u1081 \uc0\u1090 \uc0\u1072 : \uc0\u1091 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1096 \uc0\u1080 \uc0\u108